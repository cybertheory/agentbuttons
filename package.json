{
  "name": "agentbuttons",
  "version": "1.1.4",
  "description": "Drop-in buttons for every AI coding agent — Claude Code, Hermes, OpenClaw, IronClaw, and more. One import, every agent.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.js"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.mjs",
      "require": "./dist/vue.js"
    }
  },
  "unpkg": "./dist/index.global.js",
  "jsdelivr": "./dist/index.global.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai-agent",
    "coding-agent",
    "claude-code",
    "cowork",
    "hermes",
    "hermes-agent",
    "openclaw",
    "ironclaw",
    "nanoclaw",
    "zeroclaw",
    "openharness",
    "claudeclaw",
    "button",
    "web-component",
    "deploy-button"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "claudebuttons": "^1.2.8",
    "clawbuttons": "^1.0.7",
    "hermesbuttons": "^1.1.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@upstash/redis": "^1.37.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  }
}
